# --- Pulse runtime configuration --------------------------------------
# Copy to `.env.local` and fill in real values. Never commit secrets.

# AWS Aurora Serverless v2 (Postgres) — direct connection. The cluster
# uses the internet-access-gateway networking model, so a normal TLS
# Postgres URL works (no RDS Data API / Secrets Manager / IAM key).
DATABASE_URL=postgresql://postgres:<password>@pulse.cluster-cnussimqwhoc.eu-west-1.rds.amazonaws.com:5432/postgres?sslmode=require

# Kajota backend (used for JWT validation + Coach handoff + Mesh attestation).
KAJOTA_API_BASE_URL=https://kajota-mobile-backend-2.onrender.com/kajota-mobile-backend

# Gemini for the W4 "Explain why" feature (XPRIZE story). Use the same
# kajota-hackathon API key the Coach Agent v2 uses on Render.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
