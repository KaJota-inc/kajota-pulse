# --- Pulse runtime configuration --------------------------------------
# Copy to `.env.local` and fill in real values. Never commit secrets.

# AWS Aurora Serverless v2 (Postgres) — IAM token auth. This cluster
# uses the internet-access-gateway model, which REQUIRES IAM DB auth
# (static passwords are rejected). We mint a short-lived IAM token per
# connection, so the runtime needs an IAM key with rds-db:connect.
PULSE_DB_HOST=pulse.cluster-cnussimqwhoc.eu-west-1.rds.amazonaws.com
PULSE_DB_PORT=5432
PULSE_DB_USER=postgres
PULSE_DB_NAME=postgres
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# (Alternatively set DATABASE_URL for a plain password-auth Postgres.)

# Kajota backend (used for JWT validation + Coach handoff + Mesh attestation).
KAJOTA_API_BASE_URL=https://kajota-mobile-backend-2.onrender.com/kajota-mobile-backend

# Gemini for the W4 "Explain why" feature (XPRIZE story). Use the same
# kajota-hackathon API key the Coach Agent v2 uses on Render.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
